        "i18n": {
          "localized": true
        }
      }
    },
    "response_time": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "price_range": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "min_budget": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
