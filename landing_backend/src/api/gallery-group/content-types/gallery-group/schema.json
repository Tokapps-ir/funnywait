{
  "kind": "collectionType",
  "collectionName": "gallery_groups",
  "info": {
    "singularName": "gallery-group",
    "pluralName": "gallery-groups",
    "displayName": "گروه گالری",
    "description": "گروه‌بندی تصاویر گالری — هر تصویر می‌تواند عضو چند گروه باشد. برچسب‌های فیلتر بالای گالری از این گروه‌ها می‌آید."
  },
