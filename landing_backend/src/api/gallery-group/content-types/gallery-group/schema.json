      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "slug": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "required": true
    },
    "sort_order": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "default": 0
    },
    "gallery_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::gallery-item.gallery-item",
      "description": "تصاویر عضو این گروه — از طریق آیتم تصویر (Gallery Item) قابل تنظیم است.",
      "mappedBy": "gallery_groups"
    }
  }
